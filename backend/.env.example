# EMEFA Platform - Environment Variables
# Copy this file to .env and fill in the values

# App
APP_NAME=EMEFA
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://emefa:emefa@localhost:5432/emefa
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (JWT)
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Encryption (Fernet key for data at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-fernet-key

# Qdrant (Vector DB)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=emefa-uploads
S3_REGION=us-east-1

# LLM Providers
LLM_DEFAULT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenRouter (optional)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# OpenAI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# LiveKit (Voice)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Telegram Bot (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_URL=

# WhatsApp Cloud API (optional)
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp QR / Baileys (optional)
WHATSAPP_QR_ENABLED=false
WHATSAPP_QR_SERVICE_URL=http://localhost:8095

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
TOKEN_BUDGET_PER_USER_DAILY=100000
