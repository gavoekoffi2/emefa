<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgPrimary"
    android:orientation="vertical">

    <!-- Toolbar -->
    <ai.progenius.emefa.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="44dp" />

    <!-- 滚动内容 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="8dp">

            <!-- 权限分组 -->
            <ai.progenius.emefa.widget.MenuGroup
                android:id="@+id/permissionsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- 模型分组 -->
            <ai.progenius.emefa.widget.MenuGroup
                android:id="@+id/modelGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Appearance -->
            <ai.progenius.emefa.widget.MenuGroup
                android:id="@+id/appearanceGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Tools -->
            <ai.progenius.emefa.widget.MenuGroup
                android:id="@+id/toolsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Remote Control -->
            <ai.progenius.emefa.widget.MenuGroup
                android:id="@+id/remoteGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- About -->
            <ai.progenius.emefa.widget.MenuGroup
                android:id="@+id/aboutGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- 通道分组 (hidden) -->
            <ai.progenius.emefa.widget.MenuGroup
                android:id="@+id/channelGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
