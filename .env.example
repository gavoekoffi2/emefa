# ===================================
# EMEFA Platform - Environment Config
# ===================================

# App
APP_NAME=EMEFA
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://emefa:emefa@localhost:5432/emefa

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-jwt-secret-minimum-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-fernet-key

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=emefa-uploads

# LLM Providers
LLM_DEFAULT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenRouter (optional)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# OpenAI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# IronClaw (Web Gateway exposes OpenAI-compatible API on port 3000, mapped to 3001)
IRONCLAW_URL=http://localhost:3001

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret1234567890

# Telegram (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/telegram

# WhatsApp Cloud API (optional)
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp QR Bridge (unofficial - use at own risk)
WHATSAPP_QR_ENABLED=false
WHATSAPP_QR_SERVICE_URL=http://localhost:8095

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
TOKEN_BUDGET_PER_USER_DAILY=100000
